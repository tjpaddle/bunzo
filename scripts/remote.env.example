# bunzo remote builder config — example
#
# Copy this file to scripts/remote.env.local and fill in your own details.
# scripts/remote.env.local is gitignored so host info stays off GitHub.
#
#   cp scripts/remote.env.example scripts/remote.env.local
#   $EDITOR scripts/remote.env.local
#
# One-time (strongly recommended): set up key-based SSH auth so the
# scripts don't prompt for a password each run:
#
#   ssh-copy-id -p 2299 filextract@filextract-server
#

BUNZO_REMOTE_HOST=filextract-server
BUNZO_REMOTE_PORT=2299
BUNZO_REMOTE_USER=filextract
BUNZO_REMOTE_PATH=/home/filextract/bunzo
BUNZO_REMOTE_BRANCH=main

# Set to 0 to skip `git push origin <branch>` from your laptop before
# kicking off the remote build (useful if you prefer to push manually).
# BUNZO_REMOTE_PUSH=1
