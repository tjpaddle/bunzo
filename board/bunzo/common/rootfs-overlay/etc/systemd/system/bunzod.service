[Unit]
Description=bunzo agent daemon
Documentation=https://github.com/tjpaddle/bunzo
Requires=bunzod.socket
After=bunzod.socket network-online.target
Wants=network-online.target

[Service]
Type=notify
NotifyAccess=main
ExecStart=/usr/bin/bunzod
Restart=on-failure
RestartSec=2s
# bunzod now embeds wasmtime (for skill execution), which JIT-compiles WASM
# modules at startup and holds them in memory for the duration of the daemon.
# Idle RSS is a couple MB higher than the bare-LLM M3 shape; MemoryMax is
# raised from 128M → 256M as a safety net that still catches pathological
# growth.
MemoryHigh=192M
MemoryMax=256M

# No [Install] section on purpose: the service is started on demand by
# bunzod.socket the first time a client connects. Before that it idles cold.
