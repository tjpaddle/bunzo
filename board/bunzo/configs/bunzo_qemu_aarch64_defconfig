# bunzo QEMU aarch64 defconfig
#
# Builds bunzo for the QEMU `-M virt` aarch64 machine. This is the
# primary dev-loop target: fast to build, boots in seconds, same kernel
# sources as hardware targets.
#
# Consumed via:
#   make BR2_EXTERNAL=$(bunzo_repo)/board O=$(bunzo_repo)/output/qemu_aarch64 \
#        bunzo_qemu_aarch64_defconfig
#
# First-pass defconfig — expect 1-3 iterations after the first build run
# as Buildroot surfaces any missing or renamed symbols.

# --- Target architecture ---
BR2_aarch64=y
BR2_cortex_a53=y

# --- Toolchain (built from source, glibc, C++ enabled) ---
BR2_TOOLCHAIN_BUILDROOT=y
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# --- System ---
BR2_INIT_SYSTEMD=y
BR2_SYSTEM_BIN_SH_BASH=y
BR2_TARGET_GENERIC_HOSTNAME="bunzo"
BR2_TARGET_GENERIC_ISSUE="bunzo 0.0.1"
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"
BR2_SYSTEM_DHCP="eth0"

# --- Rootfs overlay + post-build hook ---
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_BUNZO_PATH)/bunzo/common/rootfs-overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_BUNZO_PATH)/bunzo/common/post-build.sh"

# --- Kernel (Linux from kernel.org, aarch64 default config + our fragment) ---
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_USE_ARCH_DEFAULT_CONFIG=y
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_BUNZO_PATH)/bunzo/common/linux.fragment"
BR2_LINUX_KERNEL_IMAGE=y

# --- Userland packages ---
BR2_PACKAGE_BASH=y
BR2_PACKAGE_COREUTILS=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_HAVEGED=y
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_SUDO=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UTIL_LINUX_BINARIES=y

# --- Root filesystem (ext4 for QEMU virtio-blk boot) ---
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"
